rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // docs/10-backend-architecture.md data model.
    // No login system: identity is the anonymous Firebase Auth uid,
    // which the client uses as deviceId.

    match /fixtures_cache/{fixtureId} {
      allow read: if true;
      allow write: if false; // written only by Cloud Functions (admin SDK)
    }

    match /devices/{deviceId} {
      allow read, write: if request.auth != null && request.auth.uid == deviceId;
    }

    match /follows/{followId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null
        && request.resource.data.deviceId == request.auth.uid;
    }

    match /user_preferences/{deviceId} {
      allow read, write: if request.auth != null && request.auth.uid == deviceId;
    }
  }
}
